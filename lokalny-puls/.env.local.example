# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_live_or_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_START=price_xxx
STRIPE_PRICE_STANDARD=price_xxx
STRIPE_PRICE_PREMIUM=price_xxx

# Groq (darmowy tier - console.groq.com)
GROQ_API_KEY=gsk_xxx

# Resend (darmowy do 3000 maili/mc - resend.com) - cotygodniowe podsumowania
RESEND_API_KEY=re_xxx

# Sekret chroniący endpointy /api/cron/* przed wywołaniem z zewnątrz
# Wygeneruj dowolny losowy ciąg, np: openssl rand -hex 32
CRON_SECRET=wygeneruj-losowy-sekret

# Email admina - jedyne konto z dostępem do /admin/seo (AI Asystent SEO)
# Musi być identyczny z emailem, którym logujesz się do panelu klienta
ADMIN_EMAIL=twoj-email@lokalnypuls.pl

# App
NEXT_PUBLIC_APP_URL=https://lokalnypuls.pl
